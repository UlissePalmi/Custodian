# Copy to .env. Vite reads it at server start, so restart the dev server
# (or `systemctl restart custodian-frontend`) after changing it.

# Where the backend API lives. The browser calls this directly, so it must be an
# address your devices can reach — not localhost, unless you only ever open the
# app on the Pi itself.
VITE_API_BASE_URL=http://192.168.50.98:8000/api

# Run the front end against the in-memory mock instead of the backend.
# VITE_USE_MOCK=true

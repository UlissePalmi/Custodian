# Copy to .env and adjust. Never commit .env.

DATABASE_URL=postgresql+psycopg://custodian:custodian@localhost:5432/custodian
TEST_DATABASE_URL=postgresql+psycopg://custodian:custodian@localhost:5432/custodian_test

# Minutes a cached price quote stays fresh before the feed is re-polled.
QUOTE_TTL_MINUTES=15

# Which origins may call the API. The front end is a separate service on its own
# port, so every browser request to this one is cross-origin. Matching the port
# on any host covers localhost, the Pi's LAN address and a Tailscale name.
CORS_ORIGIN_REGEX=http://[^/]+:5173
